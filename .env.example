# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored (covered by *.local in .gitignore).
#
# Generate a token at: https://lichess.org/account/oauth/token
# No special scopes are required — a token with zero scopes is sufficient
# for reading the public opening-explorer data.
#
# WARNING: Vite embeds VITE_* variables into the JS bundle at build time,
# so this token will be visible in the deployed site. Use a dedicated
# read-only token and do not reuse a token that has write permissions.
VITE_LICHESS_TOKEN=your_lichess_personal_access_token_here
